INTERNAL_API_BASE_URL=http://api:8000
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8000

# Join Us email delivery via Brevo SMTP.
# Use your Brevo SMTP login for SMTP_USER.
# Use your Brevo SMTP key for SMTP_PASS.
# In production, use a domain sender and authenticate the domain with SPF/DKIM/DMARC.
JOIN_REQUEST_TO_EMAIL=aktfoundation.ma@gmail.com
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Fondation AKT <no-reply@your-domain.com>"
